# --- 검증용 데모 모드 ---
# 1로 설정하면 OAuth와 Drive를 모두 우회합니다.
# Anthropic API 키 하나만 있으면 동작. 룩북은 매번 직접 업로드.
# 운영 배포(Cloud Run)에서는 반드시 0 또는 미설정.
DEMO_MODE=0

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Gemini 무료 이미지 생성 (배경 생성 폴백, 카드 등록 불필요)
# 키 발급: https://aistudio.google.com/apikey
# 무료 티어: 하루 500장, 1024x1024
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Google OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501/_oauth_callback

# Google Drive (서비스 계정 또는 OAuth 사용자 토큰)
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service-account.json
DRIVE_LOOKBOOK_FOLDER_ID=
DRIVE_LOOKBOOK_INDEX_ID=
DRIVE_OUTPUT_FOLDER_ID=

# 인증 도메인
ALLOWED_DOMAIN=duomo.co.kr

# Streamlit
STREAMLIT_SERVER_PORT=8501
