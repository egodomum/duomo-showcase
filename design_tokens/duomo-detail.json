    "brand_name": {
      "font_file": "NotoSerifDisplay-SemiBold.ttf",
      "size_desktop": 106,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    }
  },
  "layout": {
    "max_width": 1000,
    "outer_padding_x": 80,
    "section_inner_padding_y": 160,
    "divider_width": 80,
    "divider_thickness": 2,
    "align": "center"
  },
  "_layout_note": "Figma 실측 섹션 패딩은 270px이나, 합본 높이 폭증 방지를 위해 160px로 보수 적용. 단일 섹션 강조 시 확대 가능.",
  "sections": {
    "01_hero":          { "height": 1200, "mode": "image",        "background": "image_overlay_dark" },
    "02_pain":          { "height": 700,  "mode": "typo",         "background": "off-white" },
    "03_problem":       { "height": 700,  "mode": "typo",         "background": "dark" },
    "04_story":         { "height": 900,  "mode": "image_split",  "background": "off-white" },
    "05_solution":      { "height": 600,  "mode": "image",        "background": "off-white" },
    "06_how_it_works":  { "height": 800,  "mode": "image",        "background": "off-white" },
    "07_social_proof":  { "height": 900,  "mode": "typo",         "background": "dark" },
    "08_authority":     { "height": 800,  "mode": "image",        "background": "off-white" },
    "09_benefits":      { "height": 900,  "mode": "typo",         "background": "off-white" },
    "10_risk_removal":  { "height": 700,  "mode": "typo",         "background": "off-white" },
    "11_comparison":    { "height": 600,  "mode": "typo",         "background": "off-white" },
    "12_target_filter": { "height": 600,  "mode": "typo",         "background": "off-white" },
    "13_final_cta":     { "height": 900,  "mode": "image",        "background": "image_overlay_dark" }
