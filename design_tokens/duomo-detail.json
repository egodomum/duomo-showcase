{
  "preset_name": "duomo-detail",
  "_source": "DUOMO Figma 실측 (Artemide Onfale 상세페이지) — docs/playbook/visual-tone.md",
  "color": {
    "primary": "#2C2C2C",
    "secondary": "#838486",
    "accent": "#DE0515",
    "_accent_note": "브랜드별 컬러. 브리프의 brand_color로 덮어쓸 것 (Artemide=#DE0515)",
    "background": "#FFFFFF",
    "background_alt": "#2C2C2C",
    "text_primary": "#2C2C2C",
    "text_secondary": "#838486",
    "text_inverse": "#FFFFFF",
    "divider": "#C4C4C4",
    "muted": "#C4C4C4"
  },
  "typography": {
    "headline_serif": {
      "font_file": "NotoSerifDisplay-SemiBold.ttf",
      "size_desktop": 106,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "headline_serif_sub": {
      "font_file": "NotoSerifDisplay-SemiBold.ttf",
      "size_desktop": 80,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "headline_kr": {
      "font_file": "Pretendard-SemiBold.otf",
      "size_desktop": 40,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "subheadline": {
      "font_file": "Pretendard-Regular.otf",
      "size_desktop": 40,
      "letter_spacing_ratio": -0.02,
      "line_height_ratio": 1.44
    },
    "body": {
      "font_file": "Pretendard-Medium.otf",
      "size_desktop": 40,
      "letter_spacing_ratio": -0.02,
      "line_height_ratio": 1.44
    },
    "label": {
      "font_file": "Pretendard-SemiBold.otf",
      "size_desktop": 40,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "option_value": {
      "font_file": "Pretendard-Medium.otf",
      "size_desktop": 32,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "cta": {
      "font_file": "Pretendard-SemiBold.otf",
      "size_desktop": 32,
      "letter_spacing_ratio": 0,
      "line_height_ratio": 1.0
    },
    "label_uppercase": {
      "font_file": "Pretendard-SemiBold.otf",
      "size_desktop": 28,
      "letter_spacing_ratio": 0.04,
      "line_height_ratio": 1.0
